# ══════════════════════════════════════════════════════════════
#  GitHub 只保留公司门面文档（README.md + .gitignore）
#  所有技术代码、配置、密钥、数据均在本地/VPS，不上传
# ══════════════════════════════════════════════════════════════

# ── 技术源代码（不对外公开）────────────────────────────────────
scrapers/
processors/
storage/
scheduler/
config.py
models.py
requirements.txt
sync.sh

# ── 项目内部文档（含技术细节/架构，仅本地）────────────────────
CLAUDE.md
PROGRESS.md
REQUIREMENTS.md

# ── 敏感配置与密钥（绝对不能上传）────────────────────────────
.env
.env.example
credentials.json
*.json.key
service_account*.json

# ── 原始数据快照（本地生成，不入库）──────────────────────────
data/raw/*.json

# ── Python 编译缓存 ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.mypy_cache/
.ruff_cache/

# ── 虚拟环境 ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE / 编辑器 ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 测试覆盖率 / 构建产物 ─────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
dist/
build/
*.egg-info/

# ── 日志 ──────────────────────────────────────────────────────
logs/
*.log
