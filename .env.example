# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ── 汇率（每日更新）──────────────────────────────
CNY_TO_EUR=0.127

# ── ScraperAPI（用于 AliExpress 反爬）────────────
# 申请地址：https://www.scraperapi.com
SCRAPER_API_KEY=your_scraperapi_key_here

# ── Google Sheets ────────────────────────────────
# 1. 去 Google Cloud Console 创建 Service Account
# 2. 下载 JSON 密钥，放到项目根目录
# 3. 把 Sheet 共享给 Service Account 的邮箱
GOOGLE_SHEETS_CREDS_FILE=credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── eBay Developer（Finding API）────────────────
# 申请地址：https://developer.ebay.com
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here

# ── Amazon Product Advertising API 5.0 ──────────
# 步骤：
#   1. 加入 Amazon Associates 联盟：https://partnernet.amazon.de/
#   2. 等审核通过后，在后台申请 PA-API 访问权限
#   3. 在 AWS IAM 创建专用 Access Key
# 申请页面：https://affiliate-program.amazon.de/assoc_credentials/home
AMAZON_ACCESS_KEY=your_amazon_access_key_here
AMAZON_SECRET_KEY=your_amazon_secret_key_here
AMAZON_PARTNER_TAG=yourname-21        # 德国站格式末尾必须是 -21
AMAZON_MARKETPLACE=www.amazon.de      # 德国站固定值

# ── Amazon（可选，旧版 Affiliate Tag）──────────
AMAZON_AFFILIATE_TAG=
